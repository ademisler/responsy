{
  "name": "responsy",
  "version": "1.0.0",
  "description": "Minimal desktop app for live website previewing across phone, tablet, and desktop widths.",
  "private": true,
  "main": "main.js",
  "scripts": {
    "check": "node --check main.js && node --check preload.js && node --check renderer/renderer.js",
    "start": "electron .",
    "pack:win": "electron-builder --win --dir",
    "dist:win": "electron-builder --win",
    "pack:mac": "electron-builder --mac --dir",
    "dist:mac": "electron-builder --mac",
    "icon:generate": "node scripts/generate-icon.js && iconutil -c icns assets/icon.iconset -o assets/icon.icns && cp assets/icon.iconset/icon_256x256.png assets/icon.png"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ademisler/Responsy.git"
  },
  "keywords": [
    "electron",
    "responsive",
    "preview",
    "viewport",
    "screenshot",
    "desktop-app",
    "web-preview"
  ],
  "author": "Adem Isler",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ademisler/Responsy/issues"
  },
  "homepage": "https://github.com/ademisler/Responsy#readme",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "build": {
    "appId": "com.responsy.desktop",
    "productName": "Responsy",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}
